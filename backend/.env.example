# Copia este archivo como backend/.env y completa los valores.

# --- OASIS (servicios SOAP de la ESPOCH) ---
# Las operaciones de lectura funcionan sin credenciales; el login real sí las usa.
OASIS_BASE=http://swoasis.espoch.edu.ec/OASis/OAS_Interop
OASIS_USER=
OASIS_PASS=
OASIS_TIMEOUT=25

# --- Base de datos PostgreSQL (Supabase) ---
# Pega el "Connection string" (URI) de Supabase (Project Settings -> Database).
# Ejemplo: postgresql://postgres:CLAVE@db.xxxxxxxx.supabase.co:5432/postgres
# Vacío = la app usa sessionStorage como respaldo (sin persistencia compartida).
DATABASE_URL=

# --- Servidor / seguridad ---
# Origen permitido para CORS (el frontend Vite). En desarrollo "*" está bien.
CORS_ORIGIN=*

# Carpeta de logs (relativa a backend/). Se crea sola.
LOG_DIR=logs
