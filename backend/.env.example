# --- OASIS (servicios SOAP de la ESPOCH) ---
OASIS_BASE=http://swoasis.espoch.edu.ec/OASis/OAS_Interop
OASIS_USER=
OASIS_PASS=
OASIS_TIMEOUT=25

# --- Base de datos PostgreSQL (Supabase/Neon) ---
# Connection string URI de Supabase (obtener de Project Settings → Database → Connection string)
# Formato: postgresql://postgres.[PROJECT]:[PASSWORD]@aws-0-us-west-1.pooler.supabase.com:6543/postgres
# Vacío = la app usa localStorage como respaldo.
DATABASE_URL=

# --- Supabase (configuración adicional) ---
# Reemplazar [PROJECT_REF] con el ref real de tu proyecto Supabase
SUPABASE_URL=https://[PROJECT_REF].supabase.co
SUPABASE_PROJECT_REF=[PROJECT_REF]
# La service_role key solo se usa en el backend para operaciones administrativas
# NO exponer esta clave en el frontend. Obtener de Supabase Dashboard → Settings → API → service_role key
SUPABASE_SERVICE_ROLE_KEY=

# --- Coordinador por defecto (cuando se siembra la BD por primera vez) ---
COORDINATOR_EMAIL=ppaguay@espoch.edu.ec
COORDINATOR_NAME=PAUL PAGUAY
# IMPORTANTE: Cambiar esta contraseña inmediatamente después del primer inicio de sesión
COORDINATOR_PASSWORD=

# --- Servidor / seguridad ---
# Orígenes CORS permitidos (separados por coma). En producción, lista exacta de dominios.
CORS_ORIGIN=http://localhost:5173,http://localhost:5500,http://127.0.0.1:5173,http://127.0.0.1:5500
# Secreto para firmar tokens de autenticación. ¡Generar una clave aleatoria para producción!
# Ejemplo: openssl rand -hex 32
AUTH_SECRET=change_this_to_a_random_secret_key_in_production

# --- Logs ---
LOG_DIR=logs
